{
  "name": "wikisearch-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Test tooling for the Glossary app. The app itself stays build-free; this package.json exists ONLY for the dev-time test suite.",
  "scripts": {
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "test:rules": "firebase emulators:exec --only firestore \"node --test tests/rules/*.test.js\"",
    "emulators": "firebase emulators:start --only firestore,auth",
    "rules:deploy": "firebase deploy --only firestore:rules",
    "serve": "node tests/e2e/static-server.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.48.0",
    "firebase": "^11.0.0",
    "firebase-tools": "^13.0.0"
  }
}
